# EmailJS Configuration
# Get these values from https://www.emailjs.com

# Your EmailJS Public Key (found in Account > API Keys)
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here

# Your EmailJS Service ID (found in Email Services > your connected service)
VITE_EMAILJS_SERVICE_ID=your_service_id_here

# Template ID for the Contact Us form
VITE_EMAILJS_CONTACT_TEMPLATE_ID=your_contact_template_id_here

# Template ID for the Request a Quote form
VITE_EMAILJS_QUOTE_TEMPLATE_ID=your_quote_template_id_here
